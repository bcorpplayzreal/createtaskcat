//Pet picking slideshow 
var index=0;
onEvent("petPickerLeft", "click", function( ) {
  console.log(index);
  if (index==0) {
    index=petListImages.length-1;
  }
  else {
    index=(index-1);
  }
  updatePetScreen();
});

onEvent("petPickerRight", "click", function( ) {
  if (index==petListImages.length-1) {
    index=0;
  } else {
    index++;
  }
  updatePetScreen();
});

